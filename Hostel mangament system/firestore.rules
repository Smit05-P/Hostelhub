rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function userHostelId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.hostelId;
    }

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /hostels/{doc} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /hostelMembers/{doc} {
      allow read: if request.auth != null && (
        (resource != null && resource.data.userId == request.auth.uid) ||
        (resource != null && isAdmin())
      );
      allow create, update: if isAdmin() || (
        request.auth != null &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status in ["pending", "approved"]
      );
      allow delete: if isAdmin();
    }

    match /joinRequests/{doc} {
      allow read: if request.auth != null && (
        (resource != null && (resource.data.userId == request.auth.uid || isAdmin())) ||
        (resource == null && isAdmin())
      );
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /rooms/{doc} {
      allow read: if request.auth != null && (resource.data.hostelId == userHostelId() || isAdmin());
      allow write: if isAdmin() && (request.resource.data.hostelId == userHostelId() || userHostelId() == "primary-hostel");
    }

    match /complaints/{doc} {
      allow read: if request.auth != null && (resource.data.hostelId == userHostelId() || isAdmin());
      allow write: if request.auth != null && (request.resource.data.hostelId == userHostelId() || isAdmin());
    }

    match /notices/{doc} {
      allow read: if request.auth != null && (resource.data.hostelId == userHostelId() || isAdmin());
      allow write: if isAdmin() && (request.resource.data.hostelId == userHostelId() || userHostelId() == "primary-hostel");
    }

    match /fees/{doc} {
      allow read: if request.auth != null && (resource.data.hostelId == userHostelId() || isAdmin());
      allow write: if isAdmin() && (request.resource.data.hostelId == userHostelId() || userHostelId() == "primary-hostel");
    }

    match /transactions/{doc} {
      allow read: if request.auth != null && (resource.data.hostelId == userHostelId() || isAdmin());
      allow write: if isAdmin() && (request.resource.data.hostelId == userHostelId() || userHostelId() == "primary-hostel");
    }

    match /visitors/{doc} {
      allow read, write: if request.auth != null && (
        (isAdmin() && (resource == null || resource.data.hostelId == userHostelId())) ||
        (resource != null && resource.data.hostStudentId == request.auth.uid)
      );
    }

    match /visitorRequests/{doc} {
      allow read: if request.auth != null && (
        (resource != null && (resource.data.studentId == request.auth.uid || isAdmin())) ||
        (resource == null && isAdmin())
      );
      allow create: if request.auth != null && request.resource.data.studentId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{doc} {
      allow read, write: if request.auth != null && (
        resource.data.recipientId == request.auth.uid ||
        resource.data.recipientRole == "admin" && isAdmin() ||
        request.resource.data.recipientId == request.auth.uid ||
        request.resource.data.recipientRole == "admin" && isAdmin()
      );
    }
  }
}
